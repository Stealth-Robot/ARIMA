SECRET_KEY=change-me-to-a-random-64-char-hex-string
PEPPER=change-me-to-a-random-32-char-hex-string
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_FROM_NAME=A.R.I.M.A.
FLASK_ENV=development  # set to 'production' for Railway/deployed environments
RESEND_API_KEY=  # get from resend.com/api-keys
APP_URL=  # production URL for email links (e.g. https://arima.yourdomain.com)
BACKUP_ENABLED=false  # set to 'true' to enable daily R2 backups
BACKUP_R2_ENDPOINT=  # https://<account-id>.r2.cloudflarestorage.com
BACKUP_R2_ACCESS_KEY=  # R2 API access key ID
BACKUP_R2_SECRET_KEY=  # R2 API secret access key
BACKUP_R2_BUCKET=arima-backups  # R2 bucket name